<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>{{ report_title }}</title>

<style>

body{

    font-family: Arial, Helvetica, sans-serif;

    background:#f4f4f4;

    margin:40px;

}

.container{

    background:white;

    padding:30px;

    border-radius:10px;

}

h1{

    color:#0d6efd;

}

table{

    width:100%;

    border-collapse:collapse;

}

th{

    background:#0d6efd;

    color:white;

    padding:10px;

}

td{

    padding:8px;

    border-bottom:1px solid #ddd;

}

.success{

    color:green;

    font-weight:bold;

}

.failed{

    color:red;

    font-weight:bold;

}

</style>

</head>

<body>

<div class="container">

<h1>{{ company }}</h1>

<h2>{{ report_title }}</h2>

<hr>

<h3>Workflow Information</h3>

<p>

<b>Workflow:</b> {{ workflow.workflow_name }}

<br>

<b>Status:</b>

<span class="{{ workflow.status }}">

{{ workflow.status }}

</span>

<br>

<b>Run Date:</b>

{{ workflow.run_date }}

</p>

<h3>Job Summary</h3>

<table>

<tr>

<th>Host</th>

<th>Playbook</th>

<th>Status</th>

</tr>

{% for job in jobs %}

<tr>

<td>{{ job.hostname }}</td>

<td>{{ job.playbook }}</td>

<td>

<span class="{{ job.status }}">

{{ job.status }}

</span>

</td>

</tr>

{% endfor %}

</table>

</div>

</body>

</html>
